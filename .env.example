# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AGORA_APP_ID: Required for Agora RTC SDK.
# Users configure this via the Secrets panel in the AI Studio UI.
VITE_AGORA_APP_ID="e7f6e9aeecf14b2ba10e3f40be9f56e7"

# AGORA_APP_CERTIFICATE: Required if your Agora project has "App Certificate" enabled.
# If this is missing but the project requires it, you will see "dynamic use static key" errors.
AGORA_APP_CERTIFICATE="MY_AGORA_APP_CERTIFICATE"

# STRIPE_SECRET_KEY: Required for Stripe payment interactions
STRIPE_SECRET_KEY="sk_test_..."

# STRIPE_PUBLISHABLE_KEY: Used client-side for Elements or Checkout
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Master Cryptographic Core Tokens
# These act as the concrete, unchangeable cryptographic root of trust.
LIVE_KMS_TOKEN_184="AW8GRr..."
LIVE_KMS_SIGNATURE_184="ARV-wf3..."

# Stripe Rotating Key Ring Configuration
API_BEAST_MASTER="your_cryptographic_root_jwt_signing_key"

STRIPE_SK_KEYINFO="sk_live_..."
STRIPE_WH_KEYINFO="whsec_..."

STRIPE_SK_SANDBOX="sk_live_..."
STRIPE_WH_SANDBOX="whsec_..."

STRIPE_SK_SUPPORT1="sk_live_..."
STRIPE_WH_SUPPORT1="whsec_..."

STRIPE_SK_SUPPORT2="sk_live_..."
STRIPE_WH_SUPPORT2="whsec_..."

# Web3 Integration Signer Context
RPC_NODE_URL="https://cloudflare-eth.com"
PRIVATE_KEY="0x..."
CONTRACT_ADDRESS="0x..."

# GitHub Configuration for Internal Integrations
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_TOKEN="your_github_personal_access_token"
GITHUB_REPO="your_github_repository_name"
GITHUB_OWNER="your_github_username_or_organization"

